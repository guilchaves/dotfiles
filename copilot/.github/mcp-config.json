{
  "inputs": [],
  "servers": {
    "grafana-clarice": {
      "command": "uvx",
      "args": ["mcp-grafana"],
      "env": {
        "GRAFANA_URL": "",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": ""
      }
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": ""
      },
      "tools": ["query-docs", "resolve-library-id"]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "tools": ["*"],
      "args": ["-y", "chrome-devtools-mcp@latest"]
    }
  }
}
